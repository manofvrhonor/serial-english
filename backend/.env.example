# Скопируйте в backend/.env и заполните. Файл .env НЕ коммитим (он в .gitignore).

# Секрет для подписи JWT. Сгенерируйте случайную строку, напр.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Срок жизни токена (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# БД. Локально — SQLite (по умолчанию). На сервере — PostgreSQL:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/serial_english
DATABASE_URL=sqlite:///./app.db

# Кто является администратором библиотеки (через запятую). Пусто = никто.
ADMIN_EMAILS=

# Разрешённые источники для CORS (домены фронтенда, через запятую).
# Для локальной разработки можно "*".
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
